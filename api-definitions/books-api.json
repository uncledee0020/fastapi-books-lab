                            }
                        }
                    }
                }
            }
        },
        "/books/update_book": {
            "put": {
                "tags": [
                    "books"
                ],
                "summary": "Update Book",
                "description": "Update an existing book by ID.",
                "operationId": "update_book_books_update_book_put",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BookRequest"
                            },
                            "example": {
                                "author": "codingwithroby",
                                "description": "A new description of a book",
                                "published_date": 2029,
                                "rating": 5,
                                "title": "A new book"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Successful Response"
                    },
                    "422": {
                        "description": "Validation Error",
