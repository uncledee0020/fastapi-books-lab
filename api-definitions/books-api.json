    },
    "components": {
        "schemas": {
            "BookRequest": {
                "title": "BookRequest",
                "required": [
                    "title",
                    "author",
                    "description",
                    "rating",
                    "published_date"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "title": "Id",
                        "type": "integer",
                        "description": "ID is not needed on create",
                        "nullable": true
                    },
                    "title": {
                        "title": "Title",
                        "minLength": 3,
                        "type": "string"
                    },
                    "author": {
                        "title": "Author",
                        "minLength": 1,
                        "type": "string"
                    },
                    "description": {
                        "title": "Description",
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "rating": {
                        "title": "Rating",
                        "maximum": 6.0,
                        "exclusiveMaximum": true,
                        "minimum": 0.0,
                        "exclusiveMinimum": true,
                        "type": "integer"
                    },
                    "published_date": {
                        "title": "Published Date",
                        "maximum": 2031.0,
                        "exclusiveMaximum": true,
                        "minimum": 1999.0,
                        "exclusiveMinimum": true,
                        "type": "integer"
                    }
                },
                "example": {
                    "author": "codingwithroby",
                    "description": "A new description of a book",
                    "published_date": 2029,
                    "rating": 5,
                    "title": "A new book"
                }
            },
            "HTTPValidationError": {
                "title": "HTTPValidationError",
                "type": "object",
                "properties": {
                    "detail": {
                        "title": "Detail",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        }
                    }
                }
            },
            "ValidationError": {
                "title": "ValidationError",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "type": "object",
                "properties": {
                    "loc": {
                        "title": "Location",
                        "type": "array",
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        }
                    },
                    "msg": {
                        "title": "Message",
                        "type": "string"
                    },
                    "type": {
                        "title": "Error Type",
                        "type": "string"
                    }
                }
            }
        },
        "securitySchemes": {
            "apiKeyHeader": {
                "type": "apiKey",
                "name": "Ocp-Apim-Subscription-Key",
                "in": "header"
            },
            "apiKeyQuery": {
                "type": "apiKey",
                "name": "subscription-key",
                "in": "query"
            }
        }
    },
    "security": [
        {
            "apiKeyHeader": []
        },
        {
            "apiKeyQuery": []
        }
    ]
}