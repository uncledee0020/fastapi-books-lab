                                    "$ref": "#/components/schemas/HTTPValidationError"
                                },
                                "example": {
                                    "detail": [
                                        {
                                            "loc": [
                                                {}
                                            ],
                                            "msg": "string",
                                            "type": "string"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/books/": {
            "get": {
                "tags": [
                    "books"
                ],
                "summary": "Read Book By Rating",
                "description": "Retrieve books filtered by rating.",
                "operationId": "read_book_by_rating_books__get",
                "parameters": [
                    {
                        "name": "book_rating",
                        "in": "query",
                        "description": "Filter by rating (1-5)",
                        "required": true,
                        "schema": {
                            "title": "Book Rating",
                            "maximum": 6.0,
                            "exclusiveMaximum": true,
                            "minimum": 0.0,
                            "exclusiveMinimum": true,
                            "type": "integer",
                            "description": "Filter by rating (1-5)"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
