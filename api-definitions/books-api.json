                                                {}
                                            ],
                                            "msg": "string",
                                            "type": "string"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "books"
                ],
                "summary": "Delete Book",
                "description": "Delete a book by its ID.",
                "operationId": "delete_book_books__book_id__delete",
                "parameters": [
                    {
                        "name": "book_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "title": "Book Id",
                            "minimum": 0.0,
                            "exclusiveMinimum": true,
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Successful Response"
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
