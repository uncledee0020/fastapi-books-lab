        },
        "/create-book": {
            "post": {
                "tags": [
                    "books"
                ],
                "summary": "Create Book",
                "description": "Create a new book in the collection.",
                "operationId": "create_book_create_book_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BookRequest"
                            },
                            "example": {
                                "author": "codingwithroby",
                                "description": "A new description of a book",
                                "published_date": 2029,
                                "rating": 5,
                                "title": "A new book"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
