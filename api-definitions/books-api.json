                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                },
                                "example": {
                                    "detail": [
                                        {
                                            "loc": [
                                                {}
                                            ],
                                            "msg": "string",
                                            "type": "string"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/books/publish/": {
            "get": {
                "tags": [
                    "books"
                ],
                "summary": "Read Books By Publish Date",
                "description": "Retrieve books filtered by published date.",
                "operationId": "read_books_by_publish_date_books_publish__get",
                "parameters": [
                    {
                        "name": "published_date",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "title": "Published Date",
                            "maximum": 2031.0,
                            "exclusiveMaximum": true,
                            "minimum": 1999.0,
                            "exclusiveMinimum": true,
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
