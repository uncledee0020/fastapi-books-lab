                "operationId": "read_book_books__book_id__get",
                "parameters": [
                    {
                        "name": "book_id",
                        "in": "path",
                        "description": "The ID of the book to retrieve",
                        "required": true,
                        "schema": {
                            "title": "Book Id",
                            "minimum": 0.0,
                            "exclusiveMinimum": true,
                            "type": "integer",
                            "description": "The ID of the book to retrieve"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
