{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "apimName": { "type": "string" }
  },
  "resources": [
    {
      "type": "Microsoft.ApiManagement/service/products",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('apimName'), '/books-standard')]",
      "properties": {
        "displayName": "Books Standard",
        "description": "Standard access to Books API with rate limits",
        "subscriptionRequired": true,
        "approvalRequired": false,
        "state": "published"
      }
    },
    {
      "type": "Microsoft.ApiManagement/service/products",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('apimName'), '/books-unlimited')]",
      "properties": {
        "displayName": "Books Unlimited",
        "description": "Unlimited access to Books API",
        "subscriptionRequired": true,
        "approvalRequired": true,
        "state": "published"
      }
    }
  ]
}
